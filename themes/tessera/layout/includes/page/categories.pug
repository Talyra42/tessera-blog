.category-lists!= list_categories()

-
  const catsArr = site.categories.toArray().sort((a, b) => b.length - a.length)
  const total = catsArr.reduce((sum, c) => sum + c.length, 0) || 1
  const palette = ['#49B1F5', '#00C4B6', '#6F42C1', '#F0AD4E', '#FF7242', '#5CB85C', '#FF69B4', '#428BCA', '#E83E8C', '#20C997']
  let acc = 0
  const segs = catsArr.map((c, i) => {
    const start = acc / total * 100
    acc += c.length
    const end = acc / total * 100
    return { cat: c, color: palette[i % palette.length], start, end, pct: Math.round(c.length / total * 100) }
  })
  const conic = segs.length ? segs.map(s => `${s.color} ${s.start}% ${s.end}%`).join(', ') : 'var(--glass-border) 0 100%'

if catsArr.length
  .category-chart
    .category-chart-title= _p('page.category') + ' 占比'
    .category-chart-body
      .category-pie(style=`background: conic-gradient(${conic})`)
      .category-legend
        each s in segs
          a.category-legend-item(href=url_for(s.cat.path))
            span.category-legend-dot(style=`background:${s.color}`)
            span.category-legend-name= s.cat.name
            span.category-legend-pct= s.pct + '%'
