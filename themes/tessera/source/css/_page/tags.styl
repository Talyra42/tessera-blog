.tag-cloud
  &-list
    line-height: 2.4

    a
      // 多彩半透玻璃标签（颜色由 --c 变量控制，透明度用 color-mix）
      position: relative
      display: inline-flex
      align-items: center
      margin: 6px
      padding: 5px 8px 5px 14px
      border: 1px solid unquote('color-mix(in srgb, var(--c) 42%, transparent)')
      border-radius: 8px
      background: unquote('color-mix(in srgb, var(--c) 16%, transparent)')
      box-shadow: var(--card-box-shadow)
      backdrop-filter: saturate(180%) blur(12px)
      -webkit-backdrop-filter: saturate(180%) blur(12px)
      color: var(--c)
      font-weight: 500
      transition: transform .3s, box-shadow .3s, filter .3s

      &:hover
        box-shadow: var(--card-hover-box-shadow)
        filter: brightness(1.05) saturate(1.15)
        transform: translateY(-2px)

      .tag-cloud-count
        margin-left: 8px
        padding: 0 7px
        border-radius: 6px
        background: unquote('color-mix(in srgb, var(--c) 24%, transparent)')
        color: var(--c)
        font-size: .8em
        font-weight: 600

      +maxWidth768()
        zoom: .9
