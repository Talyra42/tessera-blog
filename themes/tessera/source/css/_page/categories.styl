.category-lists
  .category-title
    font-size: 2.57em

    +maxWidth768()
      font-size: 2em

  .category-list
    margin-bottom: 0

    a
      color: var(--font-color)

      &:hover
        color: $text-hover

    .category-list-count
      margin-left: 8px
      color: var(--card-meta)

      &:before
        content: '('

      &:after
        content: ')'

  ul
    padding: 0 0 0 20px
    @extend .list-beauty

    ul
      padding-left: 4px

    li
      position: relative
      margin: 6px 0
      padding: .12em .4em .12em 1.4em

// 分类占比饼图（CSS conic-gradient 甜甜圈）
.category-chart
  margin-top: 44px

  &-title
    margin-bottom: 20px
    color: var(--text-highlight-color)
    font-weight: 600
    font-size: 1.3em

  &-body
    display: flex
    flex-wrap: wrap
    align-items: center
    gap: 36px

    +maxWidth768()
      justify-content: center
      gap: 24px

  .category-pie
    flex: 0 0 auto
    width: 180px
    height: 180px
    border-radius: 50%
    // 甜甜圈中空
    -webkit-mask: radial-gradient(circle, transparent 42%, #000 43%)
    mask: radial-gradient(circle, transparent 42%, #000 43%)

  .category-legend
    display: flex
    flex: 1
    flex-direction: column
    gap: 8px
    min-width: 200px

    &-item
      display: flex
      align-items: center
      gap: 10px
      color: var(--font-color)
      transition: color .3s

      &:hover
        color: $theme-color

    &-dot
      flex: 0 0 auto
      width: 12px
      height: 12px
      border-radius: 4px

    &-name
      flex: 1
      overflow: hidden
      text-overflow: ellipsis
      white-space: nowrap

    &-pct
      flex: 0 0 auto
      color: var(--card-meta)
      font-weight: 600
      font-size: .9em
