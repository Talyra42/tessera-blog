// Tessera 首页开屏模块（home_top）
if hexo-config('home_top') && hexo-config('home_top.enable')
  #home-top
    display: flex
    margin: 0 auto
    padding: 96px 15px 0
    max-width: 1400px
    width: 100%

    // 超大屏（≥2000px）跟随 .layout：max-width 从定值切到 60% 视口宽，
    // 否则开屏模块停在 1400px，比下方文章区（.layout 同断点为 60%）窄一截
    +minWidth2000()
      max-width: 60%

    // ≤900px 与下方布局同步：侧栏消失，开屏模块堆叠
    +maxWidth900()
      flex-direction: column
      gap: 16px

    +maxWidth768()
      padding: 90px 12px 0

  // 有开屏模块时，正文区的顶部留白收窄
  #home-top ~ .layout
    padding-top: 16px

  // 左列与下方文章区同宽（74%），右侧推荐位与侧栏同宽（26% - 15px 内距）
  .home-top-left
    display: flex
    flex-direction: column
    gap: 16px
    width: 74%
    min-width: 0

    +maxWidth900()
      width: 100%

  // ---- 标语卡 + 图标墙 ----
  .htop-banner
    @extend .cardHover
    position: relative
    overflow: hidden
    padding: 34px 38px
    height: 256px

    +maxWidth768()
      padding: 24px 22px
      height: 200px

    .htop-text
      position: relative
      z-index: 2

    .htop-title
      color: var(--text-highlight-color)
      font-weight: 700
      font-size: 2.3em
      line-height: 1.35

      +maxWidth768()
        font-size: 1.7em

    .htop-site
      margin-top: 14px
      color: var(--card-meta)
      font-weight: 600
      font-size: .85em
      letter-spacing: 2px

    // 图标墙：两行反向滚动，左缘渐隐过渡，整体轻微倾斜
    .htop-iconwall
      position: absolute
      top: 50%
      right: -30px
      z-index: 1
      width: 58%
      // 无缝滚动（轨道 2 份图标平移 -50%）要求「可视窗口 ≤ 一份图标宽度」。
      // 超大屏下 home-top 变宽会把窗口撑大、超过一份宽度，回卷处露出空档而跳帧。
      // 故把窗口封顶在 1400px 断点时的已知良好宽度（58% × 74% × (1400-30) ≈ 588px），
      // 再宽的屏幕也不增长，无缝前提恒成立，与图标数量无关。
      max-width: 588px
      transform: translateY(-50%) rotate(-8deg)
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 22%, #000 92%, transparent)
      mask-image: linear-gradient(90deg, transparent, #000 22%, #000 92%, transparent)

      +maxWidth768()
        right: -50px
        width: 80%
        opacity: .4

    .htop-iconrow
      overflow: hidden
      margin: 13px 0

    // 动画放在单一轨道上（每行仅 1 个合成层）：避免多份图标各自按设备像素取整
    // 而在接缝处产生 1px 抖动（闪烁）。translate3d + backface 稳定 GPU 合成
    .htop-icontrack
      display: flex
      width: max-content
      animation: htop-marquee 28s linear infinite
      animation-delay: -14s // 负延迟：进场即处于播放中途，不暴露起始帧
      backface-visibility: hidden
      will-change: transform

    .htop-iconset
      display: flex
      flex-shrink: 0

    // 反向行：不用 animation-direction（迭代边界语义不可靠），
    // 而是整行镜像 + 图标再翻回 -- 与第一行跑同一个正向动画，行为逐像素等价
    .htop-reverse
      transform: scaleX(-1)

    .htop-reverse .htop-tile
      transform: scaleX(-1)

    .htop-reverse .htop-icontrack
      animation-delay: -7s // 与第一行错相位，避免两行同步感

    .htop-tile
      display: flex
      flex-shrink: 0
      margin-right: 14px // 用 margin 而非 gap：保证 -50% 位移无缝循环
      justify-content: center
      align-items: center
      width: 62px
      height: 62px
      border-radius: 16px
      color: #fff
      font-size: 30px
      box-shadow: 0 6px 14px rgba(0, 0, 0, .14)

      +maxWidth768()
        width: 48px
        height: 48px
        border-radius: 12px
        font-size: 23px

  // ---- 分类入口卡 ----
  .htop-categories
    display: flex
    gap: 16px

    +maxWidth768()
      gap: 10px

  // 镂空 + 磨砂玻璃：与站点卡片同一套设计令牌，配置的彩色由图标承载（渐变裁切进字形）
  .htop-cat
    position: relative
    overflow: hidden
    display: flex
    flex: 1
    align-items: center
    padding: 0 24px
    height: 84px
    border: 1px solid var(--glass-border)
    border-radius: var(--card-radius)
    background: var(--glass-bg)
    box-shadow: var(--card-box-shadow)
    backdrop-filter: saturate(180%) blur(var(--glass-blur))
    -webkit-backdrop-filter: saturate(180%) blur(var(--glass-blur))
    color: var(--text-highlight-color) !important
    transition: border-color .3s ease, box-shadow .3s ease, transform .3s ease

    +maxWidth768()
      padding: 0 14px
      height: 64px

    .htop-cat-name
      position: relative
      z-index: 2
      font-weight: 700
      font-size: 1.18em

      +maxWidth768()
        font-size: 1em

    // 半透明线框图标：描边勾勒字形轮廓、填充透明，颜色取自各卡的 accent
    .htop-cat-icon
      position: absolute
      right: 14px
      bottom: -12px
      z-index: 1
      font-size: 56px
      transform: rotate(-15deg)
      transition: transform .4s ease, opacity .4s ease
      -webkit-text-stroke: 2px var(--cat-accent)
      -webkit-text-fill-color: transparent
      opacity: .5

      +maxWidth768()
        font-size: 40px
        -webkit-text-stroke-width: 1.5px

    &:hover
      border-color: var(--cat-accent)
      box-shadow: var(--card-hover-box-shadow)
      transform: translateY(-3px)

      .htop-cat-icon
        opacity: .85
        transform: rotate(0deg) scale(1.15)

  // ---- 推荐位横幅 ----
  .htop-recommend
    @extend .cardHover
    position: relative
    overflow: hidden
    display: block
    margin-left: 15px
    width: calc(26% - 15px)
    background-position: center
    background-size: cover
    padding: 0

    +maxWidth900()
      margin-left: 0
      width: 100%
      height: 190px

    .htop-rec-mask
      position: absolute
      inset: 0
      background: linear-gradient(180deg, rgba(10, 12, 26, .72), rgba(10, 12, 26, .06) 62%)
      transition: background .3s ease

    .htop-rec-info
      position: absolute
      top: 18px
      left: 22px
      z-index: 2
      color: #fff

      .htop-rec-tips
        margin-bottom: 2px
        opacity: .75
        font-size: .82em

      .htop-rec-title
        font-weight: 700
        font-size: 1.35em
        line-height: 1.35

    .htop-rec-btn
      position: absolute
      right: 18px
      bottom: 20px
      z-index: 2
      display: flex
      gap: 7px
      align-items: center
      padding: 7px 14px
      border-radius: 24px
      background: rgba(255, 255, 255, .16)
      color: #fff
      font-size: .85em
      backdrop-filter: blur(8px)
      -webkit-backdrop-filter: blur(8px)
      transition: background .3s ease

    &:hover
      .htop-rec-btn
        background: var(--tessera-primary)

      .htop-rec-mask
        background: linear-gradient(180deg, rgba(10, 12, 26, .8), rgba(10, 12, 26, .15) 62%)

  @keyframes htop-marquee
    from
      transform: translate3d(0, 0, 0)

    to
      transform: translate3d(-50%, 0, 0)
