#pagination
  .pagination
    margin-top: 20px
    text-align: center

  .page-number
    &.current
      background: alpha($theme-color, .85)
      color: #fff

  .full-width
    width: 100% !important

  .pagination-related
    height: 150px

    +minWidth768()
      flex: 1

    .info-1
      .info-item-2
        -webkit-line-clamp: 1

    .info-2
      .info-item-1
        -webkit-line-clamp: 2

  &.pagination-post
    overflow: hidden
    margin-top: 40px
    width: 100%
    addBorderRadius(16)
    display: flex

    +maxWidth768()
      flex-direction: column

.layout
  .pagination
    & > *
      display: inline-block
      margin: 0 6px
      min-width: h = 2.6em
      height: h
      padding: 0 16px
      line-height: h

    & > *:not(.space)
      // 圆角矩形 + 磨砂玻璃（继承 .cardHover）
      @extend .cardHover
      border-radius: 12px

      &:hover
        background: alpha($theme-color, .2)
        color: $theme-color

#archive
  .pagination
    margin-top: 30px

    & > *:not(.space)
      box-shadow: none

.pagination-related
  position: relative
  display: inline-block
  overflow: hidden
  background: $dark-black
  vertical-align: bottom
  @extend .postImgHover

  &.next-post
    .info
      text-align: right

  .info
    .info-1,
    .info-2
      @extend .verticalCenter
      padding: 20px 40px
      color: var(--white)
      transition: transform .3s, opacity .3s

    .info-1
      .info-item-1
        color: var(--light-grey)
        text-transform: uppercase
        font-size: 90%

      .info-item-2
        @extend .limit-more-line
        color: var(--white)
        font-weight: 500

    .info-2
      opacity: 0
      transform: translate(0, 0)

      .info-item-1
        @extend .limit-more-line

  &:not(.no-desc):hover
    .info-1
      opacity: 0
      transform: translate(0, -100%)

    .info-2
      opacity: 1
      transform: translate(0, -50%)

  // 无封面：用磨砂玻璃 + 深色文字，仅展示标题，不再是丑陋的纯色块
  &.no-cover
    background: var(--card-bg)
    backdrop-filter: saturate(160%) blur(var(--glass-blur))
    transition: background .3s

    .info
      .info-1,
      .info-2
        color: var(--font-color)

      .info-1
        .info-item-1
          color: var(--toc-link-color)

        .info-item-2
          color: var(--font-color)

    &:hover
      background: alpha($theme-color, .14)