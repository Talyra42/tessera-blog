if hexo-config('preloader.enable') && hexo-config('preloader.source') == 1
  #loading-box
    position: fixed
    z-index: 1000
    top: 0
    left: 0
    display: flex
    flex-direction: column
    justify-content: center
    align-items: center
    width: 100%
    height: 100%
    background: var(--global-bg)
    transition: opacity .6s ease, visibility .6s ease

    .loading-stage
      display: flex
      flex-direction: column
      align-items: center

    #loading-cube
      width: 240px
      height: 240px
      cursor: grab

      +maxWidth768()
        width: 190px
        height: 190px

    .loading-word
      margin-top: 4px
      color: var(--font-color)
      font-size: 14px
      letter-spacing: 4px
      opacity: .75

    .loading-bar
      overflow: hidden
      margin-top: 18px
      width: 180px
      height: 4px
      border-radius: 4px
      background: var(--primary-soft)

      .loading-bar-inner
        width: 0
        height: 100%
        border-radius: 4px
        background: linear-gradient(90deg, $tessera-blue, $tessera-blue-light)
        transition: width .3s ease

    &.loaded
      visibility: hidden
      opacity: 0
      pointer-events: none
