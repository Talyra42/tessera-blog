// 页脚：不再是一张浮动卡片，而是页面向底部「逐渐模糊、逐渐沉淀」的收束区。
// - 自身叠一层透明 → 极淡底色的竖向渐变，让正文自然沉入底部；
// - ::before 用渐变遮罩的 backdrop-filter，把背景玻璃碎片自上而下逐渐揉化。
#footer
  position: relative
  isolation: isolate
  margin: 80px 0 0
  width: 100%
  padding-top: 40px
  color: var(--font-color)
  background: linear-gradient(to bottom, transparent 0%, var(--footer-fade) 100%)

  // 渐进模糊层：顶部完全清晰，向下平滑过渡到全模糊
  &::before
    content: ''
    position: absolute
    inset: 0
    z-index: -1
    pointer-events: none
    backdrop-filter: saturate(150%) blur(16px)
    -webkit-backdrop-filter: saturate(150%) blur(16px)
    mask-image: linear-gradient(to bottom, transparent 0%, #000 78%)
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 78%)

  +maxWidth768()
    margin-top: 56px

  a
    color: var(--font-color)
    transition: all .3s ease-in-out

    &:hover
      color: $theme-color

  .footer-separator
    margin: 0 4px

  .icp-icon
    padding: 0 4px
    max-height: 1.4em
    width: auto
    vertical-align: text-bottom

  .footer-flex
    display: flex
    flex-direction: row
    flex-wrap: wrap
    justify-content: space-between
    margin: 0 auto
    padding: 8px 48px 4px
    max-width: 1170px
    width: 100%
    text-align: left
    gap: 13px

    +minWidth2000()
      max-width: 60%

    +maxWidth768()
      padding: 0 24px
      gap: 10px

    .footer-flex-items
      flex-shrink: 0
      min-width: 100px
      text-align: left
      white-space: nowrap

    .footer-flex-title
      margin-bottom: 5px
      white-space: nowrap
      font-weight: 600
      font-size: 1.4em

    .footer-flex-item
      margin: 10px 0
      white-space: nowrap

    a
      display: block
      white-space: nowrap

  .footer-other
    margin: 0 auto
    padding: 22px 20px 28px
    max-width: 1170px
    width: 100%
    color: var(--card-meta)
    text-align: center
    font-size: .9em

    +minWidth2000()
      max-width: 60%

    a
      color: var(--card-meta)

      &:hover
        color: $theme-color

    if hexo-config('footer.nav')
      border-top: 1px solid var(--glass-border)
    else
      .framework-info
        display: block
